#!/bin/bash
# ============================================================
# Git Hook: commit-msg
# 验证提交信息是否符合约定式提交格式
#
# 安装:
#   cp tools/git/commit-msg .git/hooks/commit-msg
#   chmod +x .git/hooks/commit-msg
# ============================================================

COMMIT_MSG_FILE="$1"

# 读取提交信息（跳过注释行）
COMMIT_MSG=$(grep -v '^#' "$COMMIT_MSG_FILE" | sed '/^$/d' | head -1)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# 允许的提交类型
VALID_TYPES="feat|fix|perf|refactor|docs|test|chore|ci|style|revert|security|arch"

# 约定式提交格式 (Conventional Commits)
# <type>[optional scope]: <description>
# Merge commits 不受限制
if echo "$COMMIT_MSG" | grep -qE '^Merge '; then
    exit 0
fi

# 允许在交互式 rebase 中临时提交
if echo "$COMMIT_MSG" | grep -qE '^(fixup!|squash!)'; then
    exit 0
fi

# 验证格式: type(scope): message 或 type: message
if echo "$COMMIT_MSG" | grep -qE "^($VALID_TYPES)(\([a-zA-Z0-9_./-]+\))?: .+"; then
    echo -e "${GREEN}✓ 提交信息格式正确${NC}"
    exit 0
fi

# 格式错误
echo ""
echo -e "${RED}========================================${NC}"
echo -e "${RED}  提交信息格式不符合约定式提交规范${NC}"
echo -e "${RED}========================================${NC}"
echo ""
echo "  格式: <type>[optional scope]: <description>"
echo ""
echo "  有效类型:"
echo "    feat     新功能"
echo "    fix      Bug修复"
echo "    perf     性能优化"
echo "    refactor 代码重构"
echo "    docs     文档"
echo "    test     测试"
echo "    chore    构建/工具"
echo "    ci       CI/CD"
echo "    style    代码风格"
echo "    revert   回滚"
echo "    security 安全修复"
echo "    arch     架构变更"
echo ""
echo "  示例:"
echo "    feat(canfd): add Bus Off auto-recovery"
echo "    fix(spi): handle CRC error resync"
echo "    chore(release): prepare v1.2.0"
echo ""
echo "  当前提交信息: ${COMMIT_MSG}"
echo ""
exit 1
